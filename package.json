{
  "name": "deyad",
  "productName": "Deyad",
  "version": "1.0.1",
  "description": "Local AI app builder powered by Ollama models",
  "repository": {
    "type": "git",
    "url": "https://github.com/kennethhy/Deyad"
  },
  "main": ".vite/build/main.js",
  "private": true,
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "build:linux": "npm run make -- --platform=linux --publish never",
    "build:appimage": "npm run make -- --platform=linux --publish never && (appimagetool -n out/Deyad-linux-x64 out/make/Deyad-${npm_package_version}-x86_64.AppImage || echo \"AppImage step skipped - install appimagetool or run npx electron-installer-appimage manually\" )",
    "build:win": "npm run make -- --platform=win32 --publish never",
    "build:mac": "npm run make -- --platform=darwin --publish never",
    "lint": "eslint --ext .ts,.tsx .",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "ollama",
    "ai",
    "app-builder",
    "electron"
  ],
  "author": "Deyad",
  "license": "MIT",
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-dmg": "^6.0.0",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron-forge/plugin-vite": "^7.11.1",
    "@electron/fuses": "^1.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@types/react": "^18.3.21",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "@vitejs/plugin-react": "^4.4.1",
    "electron": "^40.8.0",
    "electron-installer-appimage": "*",
    "electron-installer-dmg": "*",
    "eslint": "^8.57.1",
    "eslint-plugin-import": "^2.32.0",
    "happy-dom": "^20.0.0",
    "typescript": "~5.7.3",
    "vite": "^5.4.21",
    "vitest": "^3.1.1"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "electron-squirrel-startup": "^1.0.1",
    "monaco-editor": "^0.55.1",
    "node-pty": "^1.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.3",
    "remark-gfm": "^4.0.1",
    "update-electron-app": "^3.1.2",
    "uuid": "^9.0.0",
    "xterm": "^5.0.1",
    "xterm-addon-fit": "^0.7.0"
  }
}
